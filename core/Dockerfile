FROM node:22-bookworm-slim

ENV NODE_ENV=production \
    PORT=3000

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends python3 make g++ \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
RUN npm ci --omit=dev

COPY src ./src

RUN mkdir -p /opt/vietarr \
  && chown -R node:node /opt/vietarr

USER node
EXPOSE 3000
CMD ["npm", "start"]
